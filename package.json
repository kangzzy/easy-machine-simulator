{
  "name": "easy-machine-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:dev": "docker compose up dev --build",
    "docker:prod": "docker compose --profile prod up prod --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "three": "^0.172.0",
    "occt-import-js": "^0.0.23"
  },
  "devDependencies": {
    "@types/three": "^0.172.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-wasm": "^3.4.1",
    "vite-plugin-top-level-await": "^1.5.0",
    "vitest": "^3.1.0"
  }
}
